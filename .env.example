# Django
DJANGO_SECRET_KEY=replace_me_secret_key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
ALLOWED_ORIGINS=http://localhost:3000

# Database
POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=password123
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Host port for the Docker postgres service. Keep it different from a local PostgreSQL.
POSTGRES_HOST_PORT=5433

# Token lifetimes in minutes/days
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=30

# Frontend build
REACT_APP_API_URL=http://localhost:8000

# Channels / Redis (optional)
CHANNEL_REDIS_URL=

# LLM provider
LLM_PROVIDER=local
LLM_MODEL=local-echo
LLM_BASE_URL=
LLM_API_KEY=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512
LLM_TIMEOUT_SECONDS=30
OLLAMA_URL=
OLLAMA_MODEL=
YC_FOLDER_ID=
YC_API_KEY=
YANDEX_GPT_MODEL_URI=
TEMPLATE_TRANSLATION_BATCH_MAX_ITEMS=24
TEMPLATE_TRANSLATION_BATCH_MAX_CHARS=7000

# Prompt history
HISTORY_MAX_PROMPT_POSTS=40
HISTORY_TAIL_UPDATE_POSTS=10
HISTORY_UPDATE_MAX_TOKENS=1200
HISTORY_UPDATE_STRICT_MAX_TOKENS=800
