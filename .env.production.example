# Production example. Use with: ENV_FILE=.env.production docker compose up --build

# Django
DJANGO_SECRET_KEY=replace_me_secret_key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=example.com
ALLOWED_ORIGINS=https://example.com

# Database
POSTGRES_DB=growth_quest
POSTGRES_USER=admin
POSTGRES_PASSWORD=replace_me_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Token lifetimes in minutes/days
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=30

# Frontend build
REACT_APP_API_URL=https://example.com

# Channels / Redis (optional but recommended in production)
CHANNEL_REDIS_URL=redis://redis:6379/0

# LLM provider
LLM_PROVIDER=yandex
LLM_MODEL=
LLM_BASE_URL=
LLM_API_KEY=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512
LLM_TIMEOUT_SECONDS=30
OLLAMA_URL=
OLLAMA_MODEL=
YC_FOLDER_ID=replace_me_folder_id
YC_API_KEY=replace_me_api_key
YANDEX_GPT_MODEL_URI=

# Prompt history
HISTORY_MAX_PROMPT_POSTS=40
HISTORY_TAIL_UPDATE_POSTS=10
HISTORY_UPDATE_MAX_TOKENS=1200
HISTORY_UPDATE_STRICT_MAX_TOKENS=800
